// Page Header 独立背景样式
// 用于替代 web_bg 的独立配置，互不影响

#page-header
  &.full_page,
  &.post-bg
    position: relative
    width: 100%
    height: 100vh
    min-height: 100vh

  .page-header-bg
    position: absolute
    top: 0
    left: 0
    width: 100%
    height: 100%
    z-index: 1
    overflow: hidden

    .banner-video
      width: 100%
      height: 100%
      object-fit: cover

// 确保 page-header 内的内容在背景之上
#page-header.full_page
  #site-info
    font-family: "anzhiyufont"
    position: relative
    width:100%
    margin: auto auto
    border: 1px solid #000000c0
    background: rgba(0, 0, 0, 0.404)
    border-radius: 12px
    z-index: 2

  #site_social_icons
    position: relative
    z-index: 2

  #subtitle
    position: relative
    z-index: 2

  #home-banner-video
    z-index: 0 !important