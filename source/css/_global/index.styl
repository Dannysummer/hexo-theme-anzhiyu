body
  position: relative
  min-height: 100vh
  color: var(--font-color)
  font-size: var(--global-font-size)
  font-family: $font-family
  line-height: $text-line-height
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0)

  // 半透明遮罩
  &::before
    content: ''
    position: fixed
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: rgba(0, 0, 0, 0.1)
    backdrop-filter: blur($glass-blur-lg)
    -webkit-backdrop-filter: blur($glass-blur-lg)
    pointer-events: none
    z-index: -1

  if !hexo-config('copy.enable')
    user-select: none

// scrollbar - chrome/safari
*::-webkit-scrollbar
  width: 6px
  height: 6px

*::-webkit-scrollbar-thumb
  background: var(--scrollbar-color)
  border-radius: 8px;
  cursor: pointer;

*::-webkit-scrollbar-track
  background-color: transparent

::-webkit-scrollbar-corner
  background-color: transparent;


// scrollbar - firefox
*
  scrollbar-width: thin
  scrollbar-color: var(--scrollbar-color) transparent

input::placeholder
  color: var(--font-color)

// 博客主容器
#blog-container
  position: relative
  & > *
    position: relative
    z-index: 1

  [data-theme="dark"] &
    &::before
      background: rgba(0, 0, 0, 0.6)

#web_bg
  position: fixed
  z-index: -999
  width: 100%
  height: 100%
  top: 0
  left: 0
  -webkit-overflow-scrolling: touch;
  background-color: var(--anzhiyu-background) !important
  background-image: url('/img/index/main.png') !important
  background-attachment: local
  background-position: center
  background-size: 100% 100%
  background-repeat: no-repeat !important

#web_bg_video
  position: fixed
  z-index: -999
  width: 100%
  height: 100%
  top: 0
  left: 0
  object-fit: cover
  pointer-events: none

  @media screen and (max-width: 768px)
    &.hide-mobile
      display: none

h1,
h2,
h3,
h4,
h5,
h6
  position: relative
  margin: 20px 0 14px
  color: var(--text-highlight-color)
  font-weight: bold

  code
    font-size: inherit !important

*
  box-sizing: border-box

hr
  position: relative
  margin: 40px auto
  border: 2px dashed var(--hr-border)

  if hexo-config('hr_icon.enable')
    width: calc(100% - 4px)

    &:hover
      &:before
        left: calc(95% - 20px)

    &:before
      position: absolute
      top: $hr-icon-top
      left: 5%
      z-index: 1
      color: var(--hr-before-color)
      content: $hr-icon
      font-size: 16px
      line-height: 1
      transition: all 1s ease-in-out
      if hexo-config('icons.fontawesome')
        @extend .fontawesomeIcon
      else
        @extend .anzhiyufont

html
  overflow-y: overlay;
.table-wrap
  overflow-x: scroll
  margin: 1rem 0;
  border-radius: 8px;

table
  display: table
  width: 100%
  border-spacing: 0
  border-collapse: collapse
  empty-cells: show
  if hexo-config('table_interlaced_discoloration')
    tr:nth-child(even)
      background-color: var(--anzhiyu-secondbg);
  thead
    background: var(--anzhiyu-secondbg);

  th,
  td
    padding: 0.3rem 0.6rem;
    vertical-align: middle
    border: var(--style-border-always);

*::selection
  background: $theme-text-selection-color
  color: #F7F7F7

button
  padding: 0
  outline: 0
  border: none
  background: none
  cursor: pointer
  touch-action: manipulation

a
  color: $a-link-color
  text-decoration: none
  word-wrap: break-word
  transition: all 0.2s ease 0s;
  overflow-wrap: break-word

  &:hover
    color: $light-blue

// font
if $site-name-font
  #site-title,
  #site-subtitle,
  #site-name,
  #aside-content .author-info__name,
  #aside-content .author-info__description
    font-family: $site-name-font

.is-center
  text-align: center

.copy-true
  user-select: all

.pull-left
  float: left

.pull-right
  float: right

img
  &[src=''],
  &:not([src])
    opacity: 0

// lazyload blur
if hexo-config('lazyload.enable') && hexo-config('lazyload.blur') && !hexo-config('lazyload.placeholder')
  img
    &[data-lazy-src]:not(.loaded)
      filter: blur(8px) brightness(1)

    &[data-lazy-src].error
      filter: none
      opacity 1 !important

// lazyload progressive
if hexo-config('lazyload.enable') && hexo-config('lazyload.progressive') && !hexo-config('lazyload.placeholder')
  img
    &[data-lazy-src]:not(.loaded)
      opacity: 0;
  img[src=''], img:not([src]) 
    opacity 0
.img-alt
  font-size: 12px;
  margin: 0;
  margin-top: 8px;
  color: var(--anzhiyu-secondtext);

  &:hover
    text-decoration: none !important

blockquote
  margin: 0 0 20px
  padding: 12px 15px
  border-left: 3px solid $blockquote-padding-color
  background-color: var(--blockquote-bg)
  color: var(--blockquote-color)

  footer
    cite
      &:before
        padding: 0 5px
        content: '—'

  & > :last-child
    margin-bottom: 0 !important
.time_hidden 
  display: none!important
#single_top
  padding: 1.875rem 1.5rem 0
  max-width: 1400px
  width 100%
  margin 0 auto
  & + #content-inner
    +maxWidth768()
      padding:1.875rem 0rem 0

// 毛玻璃+辉光效果基础类
.glass-card
  position: relative
  overflow: hidden
  background: rgba(255, 255, 255, $glass-opacity-light)
  backdrop-filter: blur($glass-blur-md)
  -webkit-backdrop-filter: blur($glass-blur-md)
  border: 1px solid rgba(255, 255, 255, $glass-border-opacity-light)
  transition: background var(--duration-normal) var(--easing-smooth),
              backdrop-filter var(--duration-normal) var(--easing-smooth),
              border-color var(--duration-normal) var(--easing-smooth),
              box-shadow var(--duration-normal) var(--easing-smooth),
              transform var(--duration-fast) var(--easing-smooth)

  &:hover
    background: rgba(255, 255, 255, $glass-opacity-light + 0.08)
    border-color: rgba(255, 255, 255, $glass-border-opacity-light + 0.15)
    box-shadow: 0 0 var(--glow-radius) var(--glow-spread) var(--glow-color),
                0 0 calc(var(--glow-radius) * 2) calc(var(--glow-spread) * 0.5) var(--glow-color)
    transform: translateY(-2px)

  // 暗色模式适配
  [data-theme="dark"] &
    background: rgba(0, 0, 0, $glass-opacity-dark)
    border-color: rgba(255, 255, 255, $glass-border-opacity-dark)

    &:hover
      background: rgba(0, 0, 0, $glass-opacity-dark + 0.05)
      border-color: rgba(255, 255, 255, $glass-border-opacity-dark + 0.1)
      box-shadow: 0 0 var(--glow-radius) var(--glow-spread) var(--glow-color),
                  0 0 calc(var(--glow-radius) * 2) calc(var(--glow-spread) * 0.5) var(--glow-color)

// 全局辉光hover效果
.glow-hover
  transition: box-shadow var(--duration-normal) var(--easing-smooth),
              transform var(--duration-fast) var(--easing-smooth)

  &:hover
    box-shadow: 0 0 var(--glow-radius) var(--glow-spread) var(--glow-color),
                0 0 calc(var(--glow-radius) * 1.5) var(--glow-spread) var(--glow-color-light)
    transform: translateY(-2px)

// 文章列表卡片 - 应用毛玻璃效果（默认状态就是透明，hover 只有辉光）
.recent-post-item
  background: rgba(255, 255, 255, $glass-opacity-light - 0.2) !important
  backdrop-filter: blur($glass-blur-md)
  -webkit-backdrop-filter: blur($glass-blur-md - 0.15)
  border: 1px solid rgba(255, 255, 255, $glass-border-opacity-light - 0.1)
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease

  &:hover
    border-color: rgba(255, 255, 255, $glass-border-opacity-light + 0.15) !important
    box-shadow: 0 0 15px 3px var(--anzhiyu-main), 0 0 30px 1.5px var(--anzhiyu-main) !important
    transform: translateY(-2px)

  [data-theme="dark"] &
    background: rgba(0, 0, 0, $glass-opacity-dark) !important
    border-color: rgba(255, 255, 255, $glass-border-opacity-dark)

    &:hover
      border-color: rgba(255, 255, 255, $glass-border-opacity-dark + 0.15) !important
      box-shadow: 0 0 15px 3px var(--anzhiyu-main), 0 0 30px 1.5px var(--anzhiyu-main) !important

// 抽拉式信息遮罩效果
.post_cover
  position: relative
  overflow: hidden

  .post-slide-overlay
    position: absolute
    bottom: 0
    left: 0
    right: 0
    transform: translateY(70%) // 默认隐藏在底部
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.3) 50%, rgba(0, 0, 0, 0.1) 100%)
    backdrop-filter: blur(5px)
    -webkit-backdrop-filter: blur(10px)
    border-radius: 2px 2px 0 0

  // 标签始终显示在左上角，不参与抽拉
  .post-cover-tips
    position: absolute
    top: 20px
    left: 20px
    z-index: 10
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 6px
    // 继承 .post-slide-overlay 内的标签样式
    .article-meta,
    .article-categories-original
      background: rgba(0, 74, 87, 0.842)
      color: #fff
      padding: 0px 10px
      border-radius: 4px
    .sticky-warp
      background: var(--anzhiyu-main)
      border-color: var(--anzhiyu-main)
    .newPost
      padding: 0px 14px;
      background: #ffc05ff0;
      color: #fff;
      font-weight: 700;
      border-radius: 6px;
      font-size: 20px;
    .unvisited-post
      padding: 0 10px
      background: rgba(255, 70, 70, 0.986)
      color: #fff
      border-radius: 4px
      // 已读状态样式
      &.is-read
        background: rgba(0, 123, 255, 0.986)
        border-color: rgba(0, 123, 255, 0.986)

    // 确保内容可滚动
    .recent-post-info
      max-height: 80vh
      overflow-y: auto
      padding: 20px
      color: #fff
      display: flex
      flex-direction: column

      &::-webkit-scrollbar
        width: 4px

      &::-webkit-scrollbar-thumb
        background: rgba(255, 255, 255, 0.3)
        border-radius: 2px

      // 调整子元素颜色
      .article-title,
      .article-meta,
      .content,
      .article-meta-label,
      .article-meta__tags,
      .article-meta-date,
      .article-meta__tags a,
      .article-meta__tags span
        color: #fff !important

      .article-meta__tags a:hover
        color: var(--anzhiyu-theme) !important

      .article-categories-original,
      .newPost,
      .unvisited-post
        background: rgba(255, 255, 255, 0.2)
        color: #fff
        border-color: rgba(255, 255, 255, 0.3)

      .sticky-warp
        background: var(--anzhiyu-main)
        border-color: var(--anzhiyu-main)

    // 第一行：标签 + 标题同一行左对齐（覆盖 homepage .article-title 的 width:100%）
    .recent-post-info-top-main
      display: flex
      flex-direction: row
      flex-wrap: nowrap
      align-items: center
      justify-content: flex-start
      gap: 8px
      margin-top: 0
      margin-bottom: 8px
      width: 100%

      .recent-post-info-top-tips
        flex-shrink: 0
        display: flex
        flex-wrap: wrap
        align-items: center
        margin-top: 0 !important

      .article-title
        flex: 1 1 auto
        min-width: 0
        width: auto !important
        margin-top: 0 !important
        margin-bottom: 0 !important
        display: block !important
        overflow: hidden
        text-overflow: ellipsis
        white-space: nowrap
        -webkit-line-clamp: unset !important
        -webkit-box-orient: unset !important

    // 第二行：日期整行右对齐
    .recent-post-info-top-meta
      display: flex
      flex-direction: row-reverse
      align-items: center
      width: 100%
      margin-bottom: 8px

      .post-meta-date
        color: rgba(255, 255, 255, 0.8) !important
        text-align: right

    // 元信息行
    .article-meta-wrap
      margin-top: auto
      margin-bottom: 5px
      gap: 10px
      padding: 0 20px !important

// hover 时抽拉上来
.post_cover:hover .post-slide-overlay
  transform: translateY(0)

// 侧边栏卡片 - 毛玻璃效果（白天模式）
// 注意：作者卡片 .card-info 有特殊背景，优先级最高，排除在外
#aside-content .card-widget:not(.card-info),
#aside-content #card-announcement,
#aside-content #card-wechat,
#aside-content #category-bar,
#aside-content #bbTimeList,
#topPostGroup > div
  background: rgba(255, 255, 255, $glass-opacity-light - 0.15) !important
  backdrop-filter: blur($glass-blur-md)
  -webkit-backdrop-filter: blur($glass-blur-md - 0.15)
  border: 1px solid rgba(255, 255, 255, $glass-border-opacity-light - 0.1)
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15)
  transition: all 0.3s ease

  &:hover
    background: rgba(255, 255, 255, $glass-opacity-light - 0.05) !important
    border-color: rgba(255, 255, 255, $glass-border-opacity-light + 0.1)
    box-shadow: 0 0 var(--glow-radius) var(--glow-spread) var(--glow-color),
                0 0 calc(var(--glow-radius) * 2) calc(var(--glow-spread) * 0.5) var(--glow-color),
                0 4px 15px rgba(0, 0, 0, 0.2)
    transform: translateY(-2px)